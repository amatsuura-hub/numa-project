# ローカル開発用の雛形 (Vite dev server で使用)。本番ビルドでは GitHub Variables
# (VITE_API_URL=https://api.numa-roadmap.com, VITE_CLOUDFRONT_URL=https://numa-roadmap.com)
# が CI から注入される。
VITE_API_URL=https://xxxxxxxxxx.execute-api.ap-northeast-1.amazonaws.com/dev
VITE_COGNITO_USER_POOL_ID=ap-northeast-1_xxxxxxxxx
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_CLOUDFRONT_URL=https://dxxxxxxxxxx.cloudfront.net
